{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"name": "Debug Melodio Application",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": [
				"run",
				"start"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": [
				"<node_internals>/**"
			],
		}
	]
}
