{
	"name": "melodio",
	"version": "1.0.0",
	"description": "Melodio - Music Player App - MERN Stack Monorepo",
	"private": true,
	"packageManager": "bun@1.1.0",
	"engines": {
		"node": ">=20.0.0",
		"bun": ">=1.0.0"
	},
	"workspaces": [
		"frontend",
		"backend"
	],
	"scripts": {
		"prestart": "bash setup.sh",
		"start": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
		"dev:frontend": "cd frontend && bun run dev",
		"dev:backend": "cd backend && bun run dev",
		"seed": "cd backend && bun run seed",
		"build": "cd frontend && bun run build && cd ../backend && bun run build",
		"clear": "rm -rf node_modules && cd backend && rm -rf node_modules dist .env && cd .. && cd frontend && rm -rf __mocks__ coverage dist node_modules .env && cd ..",
		"test:task1": "cross-env JEST_JUNIT_OUTPUT_NAME=task1.xml jest --config=jest.config.js --testPathPattern=__tests__/task1/ --passWithNoTests",
		"test:task2": "cross-env JEST_JUNIT_OUTPUT_NAME=task2.xml jest --config=jest.config.js --testPathPattern=__tests__/task2 --passWithNoTests",
		"test:task3": "cross-env JEST_JUNIT_OUTPUT_NAME=task3.xml jest --config=jest.config.js --testPathPattern=__tests__/task3 --passWithNoTests",
		"test:task4": "cross-env JEST_JUNIT_OUTPUT_NAME=task4.xml jest --config=jest.config.js --testPathPattern=__tests__/task4 --passWithNoTests",
		"test:task5": "cross-env JEST_JUNIT_OUTPUT_NAME=task5.xml jest --config=jest.config.js --testPathPattern=__tests__/task5 --passWithNoTests",
		"test:task6": "cross-env JEST_JUNIT_OUTPUT_NAME=task6.xml jest --config=jest.config.js --testPathPattern=__tests__/task6 --passWithNoTests",
		"test:task7": "cross-env JEST_JUNIT_OUTPUT_NAME=task7.xml jest --config=jest.config.js --testPathPattern=__tests__/task7 --passWithNoTests",
		"test:task8": "cross-env JEST_JUNIT_OUTPUT_NAME=task8.xml jest --config=jest.config.js --testPathPattern=__tests__/task8 --passWithNoTests",
		"test:task9": "cross-env JEST_JUNIT_OUTPUT_NAME=task9.xml jest --config=jest.config.js --testPathPattern=__tests__/task9 --passWithNoTests",
		"test:task10": "cross-env JEST_JUNIT_OUTPUT_NAME=task10.xml jest --config=jest.config.js --testPathPattern=__tests__/task10 --passWithNoTests",
		"test:task11": "cross-env JEST_JUNIT_OUTPUT_NAME=task11.xml jest --config=jest.config.js --testPathPattern=__tests__/task11 --passWithNoTests",
		"test:task12": "cross-env JEST_JUNIT_OUTPUT_NAME=task12.xml jest --config=jest.config.js --testPathPattern=__tests__/task12 --passWithNoTests",
		"test:task13": "cross-env JEST_JUNIT_OUTPUT_NAME=task13.xml jest --config=jest.config.js --testPathPattern=__tests__/task13 --passWithNoTests"
	},
	"devDependencies": {
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/identity-obj-proxy": "~3.0.2",
		"@types/jest": "^29.5.14",
		"concurrently": "^8.2.2",
		"cross-env": "^10.1.0",
		"identity-obj-proxy": "^3.0.0",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"jest-junit": "^16.0.0",
		"ts-jest": "^29.2.5"
	}
}
