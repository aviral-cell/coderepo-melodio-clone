{
	"name": "melodio",
	"version": "1.0.0",
	"devDependencies": {
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.5.2",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^2.1.0",
		"concurrently": "^8.2.2",
		"dotenv": "^16.4.7",
		"eslint": "^10.0.3",
		"globals": "^17.4.0",
		"jsdom": "^25.0.0",
		"knip": "^5.86.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-router": "^7.1.1",
		"react-router-dom": "^7.10.1",
		"supertest": "^7.0.0",
		"typescript-eslint": "^8.57.0",
		"vitest": "^2.1.0"
	},
	"description": "Melodio - Music Player App - MERN Stack Monorepo",
	"engines": {
		"node": ">=20.0.0",
		"bun": ">=1.0.0"
	},
	"packageManager": "bun@1.1.0",
	"private": true,
	"scripts": {
		"prestart": "bash setup.sh",
		"start": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
		"dev:frontend": "cd frontend && bun run dev",
		"dev:backend": "cd backend && bun run dev",
		"seed": "cd backend && bun run seed",
		"build": "cd frontend && bun run build && cd ../backend && bun run build",
		"clear": "rm -rf node_modules && cd backend && rm -rf node_modules dist .env && cd .. && cd frontend && rm -rf __mocks__ coverage dist node_modules .env && cd ..",
		"test": "bun run test:backend && bun run test:vitest",
		"test:backend": "cd backend && bun run test",
		"test:vitest": "vitest run --project frontend",
		"test:watch": "vitest --project frontend",
		"test:coverage": "cd backend && bun run test:coverage && vitest run --project frontend --coverage",
		"test:task1": "vitest run --project frontend __tests__/task1/",
		"test:task2": "vitest run --project frontend __tests__/task2/",
		"test:task3": "cd backend && jest --passWithNoTests --testPathPattern=__tests__/task3/",
		"test:task4": "cd backend && jest --passWithNoTests --testPathPattern=__tests__/task4/",
		"test:task5": "cd backend && jest --passWithNoTests --testPathPattern=__tests__/task5/",
		"test:task6": "cd backend && jest --passWithNoTests --testPathPattern=__tests__/task6/",
		"test:task7": "cd backend && jest --passWithNoTests --testPathPattern=__tests__/task7/",
		"test:task8": "vitest run --project frontend __tests__/task8/",
		"test:task9": "vitest run --project frontend __tests__/task9/",
		"test:task10": "vitest run --project frontend __tests__/task10/",
		"test:task11": "vitest run --project frontend __tests__/task11/",
		"test:task12": "cd backend && jest --passWithNoTests --testPathPattern=__tests__/task12/",
		"test:task13": "cd backend && jest --passWithNoTests --testPathPattern=__tests__/task13/",
		"lint": "bun ./scripts/quality/lint-noncandidate.mjs",
		"lint:strict": "eslint . --ext .ts,.tsx",
		"typecheck:frontend": "cd frontend && bunx tsc --noEmit --noUnusedLocals false --noUnusedParameters false",
		"typecheck:backend": "cd backend && bunx tsc --noEmit --declaration false --declarationMap false",
		"typecheck": "bun ./scripts/quality/typecheck-noncandidate.mjs",
		"typecheck:strict": "bun run typecheck:frontend && bun run typecheck:backend",
		"check:candidate-contract": "bun run unused:check",
		"check:quality": "bun run lint && bun run check:candidate-contract && bun run typecheck",
		"unused:check": "knip",
		"check:unused": "bun run unused:check"
	},
	"workspaces": [
		"frontend",
		"backend"
	]
}
