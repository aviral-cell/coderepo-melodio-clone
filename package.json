{
	"name": "hackify-music-player",
	"version": "1.0.0",
	"description": "Hackify - Music Player State Management Challenge (HackerRank Assessment)",
	"private": true,
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=10.0.0"
	},
	"workspaces": [
		"frontend",
		"backend"
	],
	"scripts": {
		"install:all": "npm install",
		"start": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
		"dev:frontend": "npm run dev --workspace=frontend",
		"dev:backend": "npm run dev --workspace=backend",
		"build": "npm run build --workspace=backend && npm run build --workspace=frontend",
		"build:frontend": "npm run build --workspace=frontend",
		"build:backend": "npm run build --workspace=backend",
		"test": "npm-run-all -c test:task1 test:task2 test:task3 test:task4",
		"test:task1": "npm run test:task1 --workspace=frontend",
		"test:task2": "npm run test:task2 --workspace=frontend",
		"test:task3": "npm run test:task3 --workspace=frontend",
		"test:task4": "npm run test:task4 --workspace=frontend",
		"test:frontend": "npm test --workspace=frontend",
		"format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,html,css,scss}\"",
		"typesync": "typesync"
	},
	"devDependencies": {
		"concurrently": "^8.2.2",
		"jest-junit": "^16.0.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.6.2",
		"typesync": "^0.14.3"
	}
}
