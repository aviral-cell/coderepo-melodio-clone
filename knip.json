{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		".": {
			"entry": ["vitest.config.frontend.mts"],
			"project": ["vitest.*.ts", "vitest.*.mts", "scripts/**/*.sh"]
		},
		"frontend": {
			"entry": [
				"src/app/routes.tsx",
				"__tests__/**/*.behavior.test.tsx",
				"test/**/*.ts",
				"test/**/*.js"
			],
			"project": ["src/**/*.ts", "src/**/*.tsx", "__tests__/**/*.tsx", "test/**/*"],
			"ignoreFiles": [
				"src/shared/components/common/ErrorMessage.tsx",
				"src/shared/components/common/LoadingSpinner.tsx",
				"src/shared/components/layout/index.ts",
				"src/shared/hooks/index.ts",
				"src/shared/hooks/useLocalStorage.ts"
			]
		},
		"backend": {
			"entry": [
				"src/app.ts",
				"__tests__/**/*.behavior.test.ts"
			],
			"project": ["src/**/*.ts", "__tests__/**/*.ts"]
		}
	},
	"ignoreDependencies": [
		"tailwindcss",
		"tailwindcss-animate",
		"@vitest/coverage-v8",
		"react",
		"react-dom"
	],
	"ignoreExportsUsedInFile": {
		"interface": true,
		"type": true
	},
	"ignoreBinaries": ["dist/server.js"]
}
