{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		".": {
			"entry": ["vitest.config.frontend.ts"],
			"project": ["vitest.*.ts", "scripts/**/*.sh"]
		},
		"frontend": {
			"entry": [
				"../candidate-contracts/candidate-frontend-contract.ts",
				"__tests__/**/*.behavior.test.tsx",
				"test/**/*.ts",
				"test/**/*.js"
			],
			"project": ["src/**/*.ts", "src/**/*.tsx", "__tests__/**/*.tsx", "test/**/*"],
			"ignoreFiles": [
				"src/shared/components/common/ErrorMessage.tsx",
				"src/shared/components/common/LoadingSpinner.tsx",
				"src/shared/components/layout/index.ts",
				"src/shared/hooks/index.ts",
				"src/shared/hooks/useLocalStorage.ts"
			]
		},
		"backend": {
			"entry": [
				"src/app.ts",
				"../candidate-contracts/candidate-backend-contract.ts",
				"__tests__/**/*.behavior.test.ts"
			],
			"project": ["src/**/*.ts", "__tests__/**/*.ts"],
			"ignoreFiles": ["src/shared/services/cache.service.ts"]
		}
	},
	"ignoreDependencies": [
		"tailwindcss",
		"tailwindcss-animate",
		"@vitest/coverage-v8"
	],
	"ignoreBinaries": ["dist/server.js"]
}
