{
	"name": "melodio-backend",
	"version": "1.0.0",
	"description": "Melodio Music Player API - Backend",
	"main": "dist/server.js",
	"scripts": {
		"dev": "bun --watch src/server.ts",
		"build": "bun build ./src/server.ts --outdir ./dist --target bun --format esm",
		"start": "bun dist/server.js",
		"seed": "tsx src/scripts/seed.ts",
		"test": "NODE_ENV=test jest --passWithNoTests",
		"test:watch": "NODE_ENV=test jest --watch --passWithNoTests",
		"test:coverage": "NODE_ENV=test jest --coverage --passWithNoTests"
	},
	"keywords": [
		"express",
		"mongodb",
		"api",
		"music",
		"backend"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"bcryptjs": "2.4.3",
		"cors": "2.8.6",
		"dotenv": "16.6.1",
		"express": "5.2.1",
		"express-validator": "7.3.1",
		"jsonwebtoken": "9.0.3",
		"mongoose": "8.23.0",
		"morgan": "1.10.1"
	},
	"devDependencies": {
		"@swc/jest": "0.2.39",
		"@types/bcryptjs": "2.4.6",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.6",
		"@types/jest": "29.5.14",
		"@types/jsonwebtoken": "9.0.10",
		"@types/morgan": "1.9.10",
		"@types/node": "22.19.15",
		"@types/supertest": "6.0.3",
		"jest": "29.7.0",
		"supertest": "7.2.2",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	}
}
