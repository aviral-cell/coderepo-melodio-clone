{
	"name": "melodio-backend",
	"version": "1.0.0",
	"description": "Melodio Music Player API - Backend",
	"main": "dist/server.js",
	"scripts": {
		"dev": "nodemon --delay 2500ms --exec tsx src/server.ts",
		"build": "tsc",
		"start": "bun dist/server.js",
		"seed": "tsx src/scripts/seed.ts",
		"test": "jest --passWithNoTests",
		"test:watch": "jest --watch --passWithNoTests",
		"test:coverage": "jest --coverage --passWithNoTests"
	},
	"keywords": [
		"express",
		"mongodb",
		"api",
		"music",
		"backend"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"express-validator": "^7.2.1",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.9.4",
		"morgan": "^1.10.0"
	},
	"devDependencies": {
		"@swc/jest": "^0.2.29",
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/morgan": "^1.9.9",
		"@types/node": "^22.10.2",
		"@types/supertest": "^6.0.2",
		"jest": "^29.7.0",
		"nodemon": "^3.1.14",
		"supertest": "^7.0.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	}
}
